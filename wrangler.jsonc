{
  // Code-level config (main, compatibility_*, triggers, observability) is merged in
  // from the upstream Worker at deploy — set only your own values here.
  "name": "grocery-mcp",
  "workers_dev": true,            // *.workers.dev URL; set false + "routes" for a custom domain
  // Cloudflare Access gate for the /admin panel (optional; unset → /admin 404).
  "vars": {
    "ACCESS_TEAM_DOMAIN": "<your-team>.cloudflareaccess.com",
    "ACCESS_AUD": "<access-app-aud>"
  },
  // Id-less → auto-provisioned on first deploy and pinned back here.
  "kv_namespaces": [
    { "binding": "KROGER_KV" },
    { "binding": "TENANT_KV" },
    { "binding": "OAUTH_KV" }
  ],
  // Id-less → provisioned on first deploy and pinned back here.
  "d1_databases": [
    { "binding": "DB", "database_name": "grocery-mcp", "migrations_dir": "migrations/d1" }
  ]
}
